# --- GIT CREDENTIALS ---
BITBUCKET_USERNAME=YOUR_USERNAME
BITBUCKET_TOKEN=YOUR_APP_PASSWORD

# --- AI CONFIGURATION ---
# Dùng host.docker.internal khi backend chạy trong Docker và model router nằm trên máy host
AI_BASE_URL=http://host.docker.internal:20128/v1
AI_API_KEY=YOUR_ROUTER_API_KEY
AI_MODEL=cx/gpt-5.4

# --- ENGINE CONFIGURATION ---
# true/false — Bật/tắt AI analysis (tắt = chỉ dùng Regex + AST)
AI_ENABLED=true

# Giới hạn số request AI chạy song song cho Validation + Deep Audit (1..100)
AI_MAX_CONCURRENCY=5

# Giới hạn số file phân tích (0 = quét toàn bộ, >0 = test mode)
TEST_MODE_LIMIT_FILES=0

# --- DATABASE CONFIGURATION ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-password
POSTGRES_DB=auditor_v2
DB_PORT=5432

# --- AUTHENTICATION ---
# Google OAuth credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
ALLOWED_EMAILS=user@example.com
JWT_SECRET_KEY=your-random-secret-key-at-least-32-chars

# true/false — Bắt buộc đăng nhập Google OAuth (false = bypass cho local dev)
AUTH_REQUIRED=true

# --- APP INFO ---
APP_VERSION=1.0.0
